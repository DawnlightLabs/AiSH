{
  "name": "aish",
  "version": "0.1.0",
  "private": true,
  "description": "AiSH provider shell and local AI command planner.",
  "workspaces": [
    "apps/site"
  ],
  "scripts": {
    "dev": "npm run site:dev",
    "build": "npm run site:build",
    "site:dev": "npm --workspace apps/site run dev",
    "site:build": "npm --workspace apps/site run build",
    "site:preview": "npm --workspace apps/site run preview",
    "provider:build": "cargo build --release -p aish-provider-shell",
    "provider:dev": "cargo run -p aish-provider-shell",
    "provider:check": "cargo check --workspace",
    "release:provider": "cargo build --release -p aish-provider-shell"
  }
}
